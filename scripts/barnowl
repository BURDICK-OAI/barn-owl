#!/usr/bin/env python3
import argparse
import json
import os
from pathlib import Path
import re
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request

DEFAULT_URL = "http://127.0.0.1:8765"
DEFAULT_APP_PATH = "/Applications/Barn Owl.app"
DEFAULT_TOKEN_PATH = Path.home() / "Library" / "Application Support" / "Barn Owl" / "control-bridge-token"
DEFAULT_LAUNCH_TIMEOUT_SECONDS = 20
DEFAULT_FEEDBACK_ERROR_PATH = Path.home() / "Library" / "Application Support" / "Barn Owl" / "last-cli-error.json"
DEFAULT_FEEDBACK_OWNER_USERNAME = "burdick"
FEEDBACK_WEBHOOK_ENV = "BARNOWL_SLACK_FEEDBACK_WEBHOOK_URL"
FEEDBACK_CHANNEL_ENV = "BARNOWL_SLACK_FEEDBACK_CHANNEL"
FEEDBACK_ERROR_PATH_ENV = "BARNOWL_FEEDBACK_ERROR_PATH"
FEEDBACK_MAX_DIAGNOSTICS_CHARS = 12_000
NON_REPORTABLE_FEEDBACK_ERROR_CODES = {
    "confirmation_required",
    "context_item_not_found",
    "meeting_not_found",
    "missing_authority_profile_id",
    "missing_context",
    "missing_context_item_id",
    "missing_description",
    "missing_display_name",
    "missing_job_id",
    "missing_knowledge_entity_id",
    "missing_meeting_id",
    "missing_meeting_type",
    "missing_policy_pack_id",
    "missing_preset_id",
    "missing_prompt",
    "missing_query",
    "missing_question",
    "missing_sync_anchor",
    "missing_source_display_name",
    "missing_source_id",
    "missing_source_type",
    "missing_slack_webhook",
    "missing_title",
    "no_active_recording",
    "no_context",
    "no_reportable_error",
    "owner_feedback_suppressed",
    "invalid_source_scope",
    "enrichment_policy_pack_not_found",
    "enrichment_source_preset_not_found",
    "enrichment_source_not_found",
    "knowledge_entity_not_found",
    "invalid_cursor",
    "unsupported_quick_command",
}
REDACTION_PATTERNS = [
    (r"sk-(proj-)?[A-Za-z0-9_-]{8,}", "[redacted API key]"),
    (r"/Users/[^\n\r\t]+/Library/Application Support/[^\n\r\t]+", "[redacted local path]"),
    (r"/Users/[^/\s]+/[^\n\r\t ]*", "[redacted local path]"),
    (r"/private/(tmp|var)/[^\n\r\t ]*", "[redacted local path]"),
    (r"/var/folders/[^\n\r\t ]*", "[redacted local path]"),
]


def command_name(value: str) -> str:
    return value.replace("-", "_")


def unavailable_response(error: Exception) -> dict:
    return {
        "ok": False,
        "message": "Barn Owl control bridge is unavailable. Is Barn Owl running?",
        "error": str(error),
    }


def redact_sensitive_text(value: str) -> str:
    sanitized = value
    for pattern, replacement in REDACTION_PATTERNS:
        sanitized = re.sub(pattern, replacement, sanitized)
    return sanitized


def redact_error_text(value: str) -> str:
    sanitized = redact_sensitive_text(value)
    if len(sanitized) > 320:
        sanitized = sanitized[:320] + "..."
    return sanitized


def sanitize_response_errors(value):
    if isinstance(value, dict):
        sanitized = {}
        for key, item in value.items():
            if key in {"error", "lastError", "errorMessage"} and isinstance(item, str):
                sanitized[key] = redact_error_text(item)
            else:
                sanitized[key] = sanitize_response_errors(item)
        return sanitized
    if isinstance(value, list):
        return [sanitize_response_errors(item) for item in value]
    return value


def feedback_error_summary(response: dict) -> dict:
    allowed_keys = [
        "ok",
        "message",
        "status",
        "recordingStatus",
        "readinessState",
        "jobState",
        "errorCode",
        "error",
        "lastError",
        "feedbackReason",
        "nextCommand",
    ]
    summary = {key: response.get(key) for key in allowed_keys if response.get(key) is not None}
    summary["capturedAt"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    return sanitize_response_errors(summary)


def feedback_error_path() -> Path:
    return Path(os.environ.get(FEEDBACK_ERROR_PATH_ENV, str(DEFAULT_FEEDBACK_ERROR_PATH))).expanduser()


def write_last_feedback_error(response: dict) -> None:
    if is_feedback_owner() or not response_has_reportable_error(response):
        return
    try:
        path = feedback_error_path()
        created_parent = not path.parent.exists()
        path.parent.mkdir(parents=True, exist_ok=True)
        if created_parent:
            path.parent.chmod(0o700)
        path.write_text(json.dumps(feedback_error_summary(response), sort_keys=True), encoding="utf-8")
        path.chmod(0o600)
    except OSError:
        pass


def read_last_feedback_error():
    try:
        return json.loads(feedback_error_path().read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None


def bridge_headers() -> dict:
    headers = {"Content-Type": "application/json"}
    token = os.environ.get("BARNOWL_BRIDGE_TOKEN")
    if token is None:
        try:
            token = DEFAULT_TOKEN_PATH.read_text(encoding="utf-8")
        except OSError:
            token = ""
    token = token.strip()
    if token:
        headers["Authorization"] = f"Bearer {token}"
    return headers


def open_barn_owl() -> None:
    app_path = os.environ.get("BARNOWL_APP", DEFAULT_APP_PATH)
    commands = [["open", "-a", "Barn Owl"]]
    if os.path.exists(app_path):
        commands.append(["open", app_path])
    try:
        for command in commands:
            subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
    except Exception:
        pass


def post_once(payload: dict, base_url: str) -> dict:
    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        f"{base_url}/command",
        data=data,
        headers=bridge_headers(),
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8")
        try:
            return json.loads(body)
        except json.JSONDecodeError:
            return {"ok": False, "message": body or str(error), "error": str(error)}
    except Exception as error:
        return unavailable_response(error)


def retry_after_launch(operation, launch: bool = True) -> dict:
    response = operation()
    if response.get("ok") or not launch or "unavailable" not in response.get("message", "").lower():
        return response
    open_barn_owl()
    try:
        launch_timeout = float(os.environ.get("BARNOWL_LAUNCH_TIMEOUT_SECONDS", DEFAULT_LAUNCH_TIMEOUT_SECONDS))
    except ValueError:
        launch_timeout = DEFAULT_LAUNCH_TIMEOUT_SECONDS
    deadline = time.monotonic() + max(1.0, launch_timeout)
    while time.monotonic() < deadline:
        time.sleep(0.5)
        response = operation()
        if response.get("ok") or "unavailable" not in response.get("message", "").lower():
            return response
    return response


def post(payload: dict, base_url: str, launch: bool = True) -> dict:
    return retry_after_launch(lambda: post_once(payload, base_url), launch=launch)


def get_status_once(base_url: str) -> dict:
    try:
        with urllib.request.urlopen(f"{base_url}/status", timeout=5) as response:
            return json.loads(response.read().decode("utf-8"))
    except Exception as error:
        return unavailable_response(error)


def get_status(base_url: str, launch: bool = True) -> dict:
    return retry_after_launch(lambda: get_status_once(base_url), launch=launch)


def parse_duration(value: str) -> float:
    text = value.strip().lower()
    if not text:
        raise argparse.ArgumentTypeError("duration cannot be empty")
    suffix = text[-1]
    multiplier = 1
    number = text
    if suffix in {"s", "m", "h"}:
        number = text[:-1]
        multiplier = {"s": 1, "m": 60, "h": 3600}[suffix]
    try:
        seconds = float(number) * multiplier
    except ValueError as error:
        raise argparse.ArgumentTypeError(f"invalid duration: {value}") from error
    if seconds < 0:
        raise argparse.ArgumentTypeError("duration must be nonnegative")
    return seconds


def wait_condition_met(response: dict, until: str) -> bool:
    if until == "stopped":
        return response.get("recordingStatus") != "recording" and response.get("status") != "Recording"
    if until == "notes":
        return response.get("notesReady") is True
    if until == "complete":
        return response.get("jobState") == "complete" and response.get("notesReady") is True
    return False


def terminal_failure(response: dict) -> bool:
    return (
        response.get("jobState") == "failed"
        or response.get("recordingStatus") == "failed"
        or response.get("errorCode") == "terminal_failure"
    )


def feedback_owner_username() -> str:
    return os.environ.get("BARNOWL_FEEDBACK_OWNER_USERNAME", DEFAULT_FEEDBACK_OWNER_USERNAME).strip()


def current_username() -> str:
    return (os.environ.get("USER") or os.environ.get("LOGNAME") or "unknown").strip()


def is_feedback_owner(username=None) -> bool:
    owner = feedback_owner_username().lower()
    current = (username or current_username()).lower()
    return bool(owner) and current == owner


def response_has_reportable_error(response: dict) -> bool:
    error_code = str(response.get("errorCode") or "").strip().lower()
    has_error_code = bool(error_code)
    has_reportable_error_code = has_error_code and error_code not in NON_REPORTABLE_FEEDBACK_ERROR_CODES
    return (
        response.get("feedbackSuggested") is True
        or response.get("jobState") == "failed"
        or bool(response.get("lastError"))
        or (has_reportable_error_code and (bool(response.get("error")) or has_error_code))
        or (response.get("ok") is False and not has_error_code)
    )


def append_feedback_suggestion(lines: list[str], response: dict) -> None:
    if response.get("feedbackSuggested") is not True:
        return
    draft_command = response.get("feedbackCommand") or "barnowl feedback slack"
    post_command = response.get("feedbackPostCommand") or "barnowl feedback slack --yes"
    reason = response.get("feedbackReason") or "This looks like a reportable Barn Owl error."
    lines.append("")
    lines.append(f"Feedback: {reason}")
    lines.append(f"Review a redacted draft with `{draft_command}`.")
    lines.append(f"Post only after confirmation with `{post_command}`.")


def default_feedback_diagnostics_path() -> str:
    timestamp = time.strftime("%Y%m%d-%H%M%S", time.gmtime())
    return f"/tmp/BarnOwl-feedback-diagnostics-{timestamp}.md"


def truncate_feedback_report(report: str) -> str:
    sanitized = redact_sensitive_text(report)
    if len(sanitized) <= FEEDBACK_MAX_DIAGNOSTICS_CHARS:
        return sanitized
    return sanitized[:FEEDBACK_MAX_DIAGNOSTICS_CHARS] + "\n\n[truncated]"


def format_feedback_message(status: dict, diagnostics_report: str, recent_error=None) -> str:
    user = current_username() or "unknown"
    host = socket.gethostname() or "unknown"
    status_line = status.get("status") or status.get("recordingStatus") or "unknown"
    readiness = status.get("readinessState") or "unknown"
    job_state = status.get("jobState") or "unknown"
    recent_error = recent_error or {}
    error = (
        recent_error.get("error")
        or recent_error.get("lastError")
        or recent_error.get("errorCode")
        or status.get("error")
        or status.get("lastError")
        or status.get("errorCode")
        or "not reported"
    )
    lines = [
        "Barn Owl feedback report",
        f"Reporter: {user}",
        f"Host: {host}",
        f"Status: {status_line}",
        f"Readiness: {readiness}",
        f"Job state: {job_state}",
        f"Error: {redact_error_text(str(error))}",
    ]
    if recent_error:
        lines.extend([
            "",
            "Recent CLI/Codex error:",
            "```json",
            json.dumps(recent_error, sort_keys=True, indent=2),
            "```",
        ])
    diagnostics = truncate_feedback_report(diagnostics_report)
    lines.extend([
        "",
        "Redacted diagnostics:",
        "```",
        diagnostics,
        "```",
    ])
    return "\n".join(lines)


def post_slack_feedback(message: str, webhook_url: str) -> dict:
    payload = {"text": message}
    channel = os.environ.get(FEEDBACK_CHANNEL_ENV, "").strip()
    if channel:
        payload["channel"] = channel
    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        webhook_url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=10) as response:
        body = response.read().decode("utf-8")
        return {
            "ok": 200 <= response.status < 300,
            "message": "Slack feedback posted." if 200 <= response.status < 300 else "Slack feedback post failed.",
            "slackStatus": response.status,
            "slackResponse": body[:320],
        }


def feedback_slack(args, base_url: str, launch: bool, output_format: str, human: bool) -> int:
    if is_feedback_owner() and not args.force:
        return print_response({
            "ok": False,
            "message": "Current macOS user is configured as the Barn Owl owner; feedback auto-suggestion is for non-owner users.",
            "errorCode": "owner_feedback_suppressed",
            "nextCommand": "Use `barnowl feedback slack --force` to draft anyway or `barnowl feedback slack --yes --force` to post.",
        }, output_format, human)

    status = get_status(base_url, launch=launch)
    recent_error = read_last_feedback_error()
    has_reportable_status = response_has_reportable_error(status)
    has_recent_error = bool(recent_error) and response_has_reportable_error(recent_error)
    if not has_reportable_status and not has_recent_error and not args.force:
        return print_response({
            "ok": False,
            "message": "Barn Owl does not currently show a reportable error.",
            "errorCode": "no_reportable_error",
            "nextCommand": "Use `barnowl feedback slack --force` to draft a report anyway.",
        }, output_format, human)

    output_path = args.output or default_feedback_diagnostics_path()
    diagnostics = post(
        {
            "command": "diagnostics_export",
            "outputPath": output_path,
            "format": "json",
        },
        base_url,
        launch=launch,
    )
    if diagnostics.get("ok") is False:
        return print_response(diagnostics, output_format, human)

    try:
        diagnostics_report = Path(output_path).read_text(encoding="utf-8")
    except OSError as error:
        return print_response({
            "ok": False,
            "message": "Could not read exported Barn Owl diagnostics.",
            "errorCode": "diagnostics_read_failed",
            "error": str(error),
        }, output_format, human)

    message = format_feedback_message(status, diagnostics_report, recent_error=recent_error)
    if not args.yes:
        return print_response({
            "ok": True,
            "message": "Slack feedback draft ready. Nothing was posted.",
            "feedbackDraft": message,
            "feedbackCommand": "barnowl feedback slack --yes",
            "diagnosticsPath": output_path,
            "nextCommand": "Review the draft, then run `barnowl feedback slack --yes` to post.",
        }, output_format, human)

    webhook_url = os.environ.get(FEEDBACK_WEBHOOK_ENV, "").strip()
    if not webhook_url:
        return print_response({
            "ok": False,
            "message": f"Slack feedback webhook is not configured. Set {FEEDBACK_WEBHOOK_ENV} before posting.",
            "errorCode": "missing_slack_webhook",
            "diagnosticsPath": output_path,
            "nextCommand": "Set the feedback webhook, then rerun `barnowl feedback slack --yes`.",
        }, output_format, human)

    try:
        result = post_slack_feedback(message, webhook_url)
    except Exception as error:
        return print_response({
            "ok": False,
            "message": "Could not post Barn Owl feedback to Slack.",
            "errorCode": "slack_post_failed",
            "error": str(error),
            "diagnosticsPath": output_path,
        }, output_format, human)

    result["diagnosticsPath"] = output_path
    return print_response(result, output_format, human)


def wait_for_condition(payload: dict, base_url: str, timeout_seconds: float, launch: bool = True) -> dict:
    deadline = time.monotonic() + timeout_seconds
    until = payload.get("until", "complete")
    last_response = None
    interval = 1.0
    while True:
        response = post(payload, base_url, launch=launch)
        last_response = response
        if response.get("ok") is False:
            return response
        if wait_condition_met(response, until):
            response["ok"] = True
            response["message"] = response.get("message") or f"Wait condition satisfied: {until}."
            return response
        if terminal_failure(response):
            response["ok"] = False
            response["errorCode"] = response.get("errorCode") or "terminal_failure"
            response["message"] = response.get("message") or "Barn Owl reached a failed state."
            return response
        if time.monotonic() >= deadline:
            timeout_response = dict(last_response or {})
            timeout_response["ok"] = False
            timeout_response["errorCode"] = "timeout"
            timeout_response["error"] = f"Timed out waiting for {until} after {timeout_seconds:g}s."
            timeout_response["message"] = timeout_response["error"]
            return timeout_response
        time.sleep(min(interval, max(0.1, deadline - time.monotonic())))
        interval = min(interval * 1.2, 2.0)


def markdown_response(response: dict) -> str:
    if response.get("feedbackDraft"):
        lines = ["# Barn Owl Feedback Draft", ""]
        lines.append(response["feedbackDraft"])
        if response.get("nextCommand"):
            lines.append("")
            lines.append(response["nextCommand"])
        return "\n".join(lines).rstrip()
    if response.get("jobs") is not None:
        lines = ["# Barn Owl Jobs"]
        jobs = response.get("jobs") or []
        if not jobs:
            lines.append("")
            lines.append("No jobs found.")
        for status in ["failed", "running", "pending", "succeeded", "canceled"]:
            grouped = [job for job in jobs if job.get("status") == status]
            if not grouped:
                continue
            lines.append("")
            lines.append(f"## {status.title()}")
            for job in grouped:
                detail = f"- `{job.get('id')}` {job.get('type', 'job')}"
                if job.get("meetingID"):
                    detail += f" meeting `{job['meetingID']}`"
                detail += f" attempts={job.get('attemptCount', 0)} updated={job.get('updatedAt', 'unknown')}"
                lines.append(detail)
                if job.get("errorMessage"):
                    lines.append(f"  - Error: {job['errorMessage']}")
        if response.get("nextCommand"):
            lines.append("")
            lines.append(f"Next: `{response['nextCommand']}`")
        append_feedback_suggestion(lines, response)
        return "\n".join(lines).rstrip()
    if response.get("enrichmentSources") is not None:
        lines = ["# Enrichment Sources"]
        sources = response.get("enrichmentSources") or []
        if not sources:
            lines.append("")
            lines.append("No enrichment sources configured.")
        for source in sources:
            state = "enabled" if source.get("enabled") else "disabled"
            lines.append("")
            lines.append(f"## {source.get('displayName', source.get('id', 'source'))} `{source.get('id', 'unknown')}`")
            lines.append(f"- State: {state}")
            lines.append(f"- Type: {source.get('sourceType', 'unknown')}")
            lines.append(f"- Scope: {source.get('scopeLabel') or source.get('scope', 'unknown')}")
            lines.append(f"- Status: {source.get('healthLabel') or source.get('healthStatus', 'unknown')}")
            lines.append(f"- Auth: {source.get('authState', 'unknown')}")
            lines.append(f"- Authority: {source.get('authorityProfile', 'unknown')}")
            if source.get("bestUsedFor"):
                lines.append(f"- Best for: {', '.join(source['bestUsedFor'])}")
            if source.get("lastCheckedAt"):
                lines.append(f"- Last checked: {source['lastCheckedAt']}")
        policy_packs = response.get("enrichmentPolicyPacks") or []
        if policy_packs:
            lines.append("")
            lines.append("## Policy Packs")
            for pack in policy_packs:
                state = "active" if pack.get("active") else "inactive"
                lines.append("")
                lines.append(f"### {pack.get('displayName', pack.get('id', 'policy'))} `{pack.get('id', 'unknown')}`")
                lines.append(f"- State: {state}")
                lines.append(f"- Promote after: {pack.get('minimumSupportingEvidenceCount', 0)} evidence items")
                lines.append(
                    f"- Conflict memory requires: {pack.get('minimumIndependentSourceCountAfterConflictMemory', 0)} independent sources"
                )
                if pack.get("description"):
                    lines.append(f"- {pack['description']}")
        authority_profiles = response.get("enrichmentAuthorityProfiles") or []
        if authority_profiles:
            lines.append("")
            lines.append("## Authority Profiles")
            for profile in authority_profiles:
                lines.append("")
                lines.append(f"### {profile.get('displayName', profile.get('id', 'profile'))} `{profile.get('id', 'unknown')}`")
                lines.append(f"- Built in: {'yes' if profile.get('builtIn') else 'no'}")
                lines.append(f"- Default weight: {profile.get('defaultWeight', 0)}")
                strongest = profile.get("strongestEntityKinds") or []
                if strongest:
                    lines.append(f"- Strongest for: {', '.join(strongest)}")
                weakest = profile.get("weakestEntityKinds") or []
                if weakest:
                    lines.append(f"- Weakest for: {', '.join(weakest)}")
                if profile.get("description"):
                    lines.append(f"- {profile['description']}")
        append_feedback_suggestion(lines, response)
        return "\n".join(lines).rstrip()
    if response.get("enrichmentSourcePresets") is not None:
        lines = ["# Enrichment Source Presets"]
        presets = response.get("enrichmentSourcePresets") or []
        if not presets:
            lines.append("")
            lines.append("No enrichment source presets available.")
        for preset in presets:
            lines.append("")
            lines.append(f"## {preset.get('displayName', preset.get('id', 'preset'))} `{preset.get('id', 'unknown')}`")
            lines.append(f"- Type: {preset.get('sourceType', 'unknown')}")
            lines.append(f"- Scope: {preset.get('scopeLabel') or preset.get('scope', 'unknown')}")
            lines.append(f"- Authority: {preset.get('authorityProfile', 'unknown')}")
            if preset.get("connectorReference"):
                lines.append(f"- Connector: {preset['connectorReference']}")
            if preset.get("bestUsedFor"):
                lines.append(f"- Best for: {', '.join(preset['bestUsedFor'])}")
            lines.append(f"- Default auth: {preset.get('defaultAuthState', 'unknown')}")
            lines.append(f"- Default health: {preset.get('defaultHealthStatus', 'unknown')}")
        return "\n".join(lines).rstrip()
    if response.get("enrichmentAuthorityProfiles") is not None:
        lines = ["# Authority Profiles"]
        profiles = response.get("enrichmentAuthorityProfiles") or []
        if not profiles:
            lines.append("")
            lines.append("No enrichment authority profiles configured.")
        for profile in profiles:
            lines.append("")
            lines.append(f"## {profile.get('displayName', profile.get('id', 'profile'))} `{profile.get('id', 'unknown')}`")
            lines.append(f"- Built in: {'yes' if profile.get('builtIn') else 'no'}")
            lines.append(f"- Default weight: {profile.get('defaultWeight', 0)}")
            strongest = profile.get("strongestEntityKinds") or []
            if strongest:
                lines.append(f"- Strongest for: {', '.join(strongest)}")
            weakest = profile.get("weakestEntityKinds") or []
            if weakest:
                lines.append(f"- Weakest for: {', '.join(weakest)}")
            if profile.get("description"):
                lines.append(f"- {profile['description']}")
        return "\n".join(lines).rstrip()
    if response.get("enrichmentPolicyPacks") is not None:
        lines = ["# Policy Packs"]
        packs = response.get("enrichmentPolicyPacks") or []
        if not packs:
            lines.append("")
            lines.append("No enrichment policy packs configured.")
        for pack in packs:
            state = "active" if pack.get("active") else "inactive"
            lines.append("")
            lines.append(f"## {pack.get('displayName', pack.get('id', 'policy'))} `{pack.get('id', 'unknown')}`")
            lines.append(f"- State: {state}")
            lines.append(f"- Promote after: {pack.get('minimumSupportingEvidenceCount', 0)} evidence items")
            lines.append(
                f"- Conflict memory requires: {pack.get('minimumIndependentSourceCountAfterConflictMemory', 0)} independent sources"
            )
            if pack.get("description"):
                lines.append(f"- {pack['description']}")
        return "\n".join(lines).rstrip()
    if (
        response.get("bridgeStatus") or response.get("recordingStatus") or response.get("nextCommand")
    ) and not any(response.get(key) for key in [
        "notes",
        "transcript",
        "summary",
        "answer",
        "actions",
        "decisions",
        "contextItems",
        "meetings",
        "meeting",
        "current",
    ]):
        if "wait" in response.get("message", "").lower() or response.get("errorCode") in {"timeout", "terminal_failure"}:
            lines = ["# Barn Owl Wait", ""]
            state = "complete" if response.get("ok") else "failed"
            if response.get("errorCode") == "timeout":
                state = "timed out"
            lines.append(f"- Result: {state}")
            lines.append(f"- Message: {response.get('message', 'Barn Owl wait response.')}")
            if response.get("meetingID"):
                lines.append(f"- Meeting: `{response['meetingID']}`")
            lines.append(f"- Job state: {response.get('jobState') or 'unknown'}")
            if response.get("captureStatus"):
                lines.append(f"- Capture: {response['captureStatus']}")
            if response.get("realtimeStatus"):
                lines.append(f"- Realtime preview: {response['realtimeStatus']}")
            if response.get("finalTranscriptionStatus"):
                lines.append(f"- High-quality pass: {response['finalTranscriptionStatus']}")
            lines.append(f"- Notes: {'ready' if response.get('notesReady') else 'not ready'}")
            lines.append(f"- Transcript: {'ready' if response.get('transcriptReady') else 'not ready'}")
            lines.append(f"- Summary: {'ready' if response.get('summaryReady') else 'not ready'}")
            if response.get("lastError"):
                lines.append(f"- Last error: {response['lastError']}")
            if response.get("nextCommand"):
                lines.append("")
                lines.append(f"Next: `{response['nextCommand']}`")
            append_feedback_suggestion(lines, response)
            return "\n".join(lines).rstrip()
        lines = ["# Barn Owl Status", ""]
        checks = [
            ("Bridge", response.get("bridgeStatus") or "unknown"),
            ("App", response.get("appStatus") or "unknown"),
            ("Recording", response.get("recordingStatus") or response.get("status") or "unknown"),
            ("API key", "verified" if response.get("apiKeyVerified") else ("saved, test needed" if response.get("apiKeyConfigured") else "missing")),
            ("Readiness", response.get("readinessState") or "unknown"),
            ("Jobs", response.get("jobState") or "unknown"),
            ("Notes", "ready" if response.get("notesReady") else "not ready"),
            ("Transcript", "ready" if response.get("transcriptReady") else "not ready"),
            ("Summary", "ready" if response.get("summaryReady") else "not ready"),
        ]
        for label, value in checks:
            mark = "x" if value in {"configured", "verified", "ready", "complete", "running"} else " "
            lines.append(f"- [{mark}] {label}: {value}")
        if response.get("meetingID"):
            lines.append(f"- Meeting: `{response['meetingID']}`")
        if response.get("sessionID"):
            lines.append(f"- Session: `{response['sessionID']}`")
        if response.get("title"):
            lines.append(f"- Title: {response['title']}")
        if response.get("captureStatus"):
            lines.append(f"- Capture: {response['captureStatus']}")
        if response.get("realtimeStatus"):
            lines.append(f"- Realtime preview: {response['realtimeStatus']}")
        if response.get("finalTranscriptionStatus"):
            lines.append(f"- High-quality pass: {response['finalTranscriptionStatus']}")
        if response.get("lastError"):
            lines.append(f"- Last error: {response['lastError']}")
        if response.get("nextCommand"):
            lines.append("")
            lines.append(f"Next: `{response['nextCommand']}`")
        append_feedback_suggestion(lines, response)
        return "\n".join(lines).rstrip()
    if response.get("meetingEvidenceBatch"):
        batch = response["meetingEvidenceBatch"]
        sync = batch.get("sync") or {}
        items = batch.get("items") or []
        lines = ["# Barn Owl Meeting Evidence Batch", ""]
        lines.append(f"- Returned: {sync.get('returnedCount', len(items))}")
        lines.append(f"- Limit: {sync.get('limit', 'unknown')}")
        lines.append(f"- Has more: {sync.get('hasMore', False)}")
        if sync.get("requestedSince"):
            lines.append(f"- Since: {sync['requestedSince']}")
        if sync.get("requestedCursor"):
            lines.append(f"- Cursor: {sync['requestedCursor']}")
        if sync.get("nextSince"):
            lines.append(f"- Next since: {sync['nextSince']}")
        if sync.get("nextCursor"):
            lines.append(f"- Next cursor: {sync['nextCursor']}")
        if items:
            lines.append("")
            lines.append("## Meetings")
            lines.append("")
            for item in items:
                meeting = item.get("meeting") or {}
                processing = item.get("processing") or {}
                title = meeting.get("title", "Untitled meeting")
                stable_key = meeting.get("stableKey", "unknown")
                readiness = processing.get("ingestReadiness", "unknown")
                updated_at = meeting.get("updatedAt", "unknown")
                lines.append(f"- {title} | `{stable_key}` | {readiness} | updated {updated_at}")
        return "\n".join(lines).rstrip()
    if response.get("meetingExportEventBatch"):
        batch = response["meetingExportEventBatch"]
        sync = batch.get("sync") or {}
        items = batch.get("items") or []
        lines = ["# Barn Owl Meeting Export Events", ""]
        lines.append(f"- Returned: {sync.get('returnedCount', len(items))}")
        lines.append(f"- Limit: {sync.get('limit', 'unknown')}")
        lines.append(f"- Has more: {sync.get('hasMore', False)}")
        if sync.get("requestedSince"):
            lines.append(f"- Since: {sync['requestedSince']}")
        if sync.get("requestedCursor"):
            lines.append(f"- Cursor: {sync['requestedCursor']}")
        if sync.get("nextSince"):
            lines.append(f"- Next since: {sync['nextSince']}")
        if sync.get("nextCursor"):
            lines.append(f"- Next cursor: {sync['nextCursor']}")
        if items:
            lines.append("")
            lines.append("## Events")
            lines.append("")
            for item in items:
                event_type = item.get("type", "unknown")
                stable_key = item.get("meetingStableKey", "unknown")
                occurred_at = item.get("occurredAt", "unknown")
                suffix = ""
                if item.get("tombstoneReason"):
                    suffix = f" | {item['tombstoneReason']}"
                lines.append(f"- {event_type} | `{stable_key}` | {occurred_at}{suffix}")
        return "\n".join(lines).rstrip()
    if response.get("meetingEvidence"):
        evidence = response["meetingEvidence"]
        meeting = evidence.get("meeting") or {}
        processing = evidence.get("processing") or {}
        lines = [f"# {meeting.get('title', 'Barn Owl Meeting Evidence')}"]
        lines.append("")
        lines.append(f"- Stable key: `{meeting.get('stableKey', 'unknown')}`")
        lines.append(f"- Readiness: {processing.get('ingestReadiness', 'unknown')}")
        lines.append(f"- Policy: {(evidence.get('provenance') or {}).get('contentPolicy', 'unknown')}")
        if meeting.get("updatedAt"):
            lines.append(f"- Updated: {meeting['updatedAt']}")
        summary = ((evidence.get("derived") or {}).get("summary") or {}).get("overview")
        if summary:
            lines.append("")
            lines.append("## Summary")
            lines.append("")
            lines.append(summary)
        transcript = (((evidence.get("artifacts") or {}).get("transcript") or {}).get("text"))
        if transcript:
            lines.append("")
            lines.append("## Transcript")
            lines.append("")
            lines.append(transcript)
        return "\n".join(lines).rstrip()
    if response.get("notes"):
        return response["notes"].rstrip()
    if response.get("diagnosticsPath"):
        lines = ["# Developer Diagnostics", ""]
        lines.append(f"Exported: `{response['diagnosticsPath']}`")
        if response.get("nextCommand"):
            lines.append("")
            lines.append(response["nextCommand"])
        append_feedback_suggestion(lines, response)
        return "\n".join(lines).rstrip()
    if response.get("transcript"):
        return "# Transcript\n\n" + response["transcript"].rstrip()
    if response.get("summary"):
        return "# Summary\n\n" + response["summary"].rstrip()
    if response.get("answer"):
        return response["answer"].rstrip()
    if response.get("actions") or response.get("decisions"):
        parts = []
        if response.get("actions"):
            parts.append("## Action Items\n\n" + "\n".join(f"- {item}" for item in response["actions"]))
        if response.get("decisions"):
            parts.append("## Decisions\n\n" + "\n".join(f"- {item}" for item in response["decisions"]))
        return "\n\n".join(parts)
    if response.get("contextItems"):
        lines = ["# Context"]
        for item in response["contextItems"]:
            lines.append("")
            lines.append(f"## {item.get('source', 'context')} ({item.get('state', 'unknown')}) `{item.get('id')}`")
            if item.get("meetingID"):
                lines.append(f"Meeting: `{item['meetingID']}`")
                lines.append("")
            lines.append(item.get("body", ""))
        return "\n".join(lines).rstrip()
    if response.get("enrichmentJobs") is not None:
        lines = ["# Enrichment Jobs"]
        jobs = response.get("enrichmentJobs") or []
        if not jobs:
            lines.append("")
            lines.append("No enrichment jobs found.")
        for job in jobs:
            lines.append("")
            lines.append(f"## {job.get('conceptKey', 'concept')} `{job.get('id')}`")
            lines.append(f"- Status: {job.get('statusLabel') or job.get('status', 'unknown')}")
            lines.append(f"- Evidence: {job.get('evidenceCount', 0)}")
            selected = job.get("selectedSources") or []
            if selected:
                lines.append(f"- Sources: {', '.join(selected)}")
            if job.get("summary"):
                lines.append("")
                lines.append(job["summary"])
            if job.get("rationale"):
                lines.append("")
                lines.append(f"Rationale: {job['rationale']}")
        evidence = response.get("enrichmentEvidence") or []
        if evidence:
            lines.append("")
            lines.append("## Evidence")
            for item in evidence:
                lines.append("")
                lines.append(f"- **{item.get('sourceDisplayName', item.get('sourceID', 'source'))}**: {item.get('summary', '')}")
        concept_histories = response.get("enrichmentConceptHistories") or []
        if concept_histories:
            lines.append("")
            lines.append("## Concept Memory")
            for history in concept_histories:
                lines.append("")
                lines.append(f"### {history.get('conceptKey', 'concept')}")
                lines.append(f"- Supported jobs: {history.get('supportedCandidateJobs', 0)}")
                lines.append(f"- Conflicted jobs: {history.get('conflictingJobs', 0)}")
                lines.append(f"- Negative evidence items: {history.get('negativeEvidenceItems', 0)}")
                if history.get("requiresConflictMemoryHold"):
                    lines.append("- Automation threshold: higher bar active because prior conflict memory exists")
                else:
                    lines.append("- Automation threshold: standard")
        return "\n".join(lines).rstrip()
    if response.get("knowledgeEntities") is not None:
        lines = ["# Durable Knowledge Entities"]
        entities = response.get("knowledgeEntities") or []
        if not entities:
            lines.append("")
            lines.append("No durable knowledge entities recorded.")
        for entity in entities:
            lines.append("")
            lines.append(f"## {entity.get('canonicalName', 'entity')} `{entity.get('id', 'unknown')}`")
            lines.append(f"- Kind: {entity.get('kind', 'unknown')}")
            lines.append(f"- Confidence: {entity.get('confidence', 0)}")
            lines.append(f"- Lifecycle: {entity.get('lifecycleStatus', 'unknown')}")
            if entity.get("lifecycleReason"):
                lines.append(f"- Reason: {entity['lifecycleReason']}")
            if entity.get("summary"):
                lines.append("")
                lines.append(entity["summary"])
        return "\n".join(lines).rstrip()
    if response.get("meetings"):
        lines = ["# Meetings"]
        for meeting in response["meetings"]:
            started = meeting.get("startedAt") or "unknown date"
            overview = meeting.get("overview") or ""
            lines.append(f"\n- **{meeting.get('title', 'Untitled Meeting')}** `{meeting.get('id')}`")
            lines.append(f"  - Started: {started}")
            if meeting.get("meetingType"):
                lines.append(f"  - Type: {meeting['meetingType']}")
            if overview:
                lines.append(f"  - {overview}")
        return "\n".join(lines).rstrip()
    if response.get("meeting") or response.get("current"):
        meeting = response.get("meeting") or response.get("current")
        lines = [f"# {meeting.get('title', 'Barn Owl Meeting')}"]
        lines.append("")
        lines.append(f"- ID: {meeting.get('id')}")
        if meeting.get("startedAt"):
            lines.append(f"- Started: {meeting['startedAt']}")
        if meeting.get("meetingType"):
            lines.append(f"- Type: {meeting['meetingType']}")
        if meeting.get("status"):
            lines.append(f"- Status: {meeting['status']}")
        if meeting.get("overview"):
            lines.append("")
            lines.append(meeting["overview"])
        return "\n".join(lines).rstrip()
    lines = [response.get("message", "Barn Owl response.")]
    append_feedback_suggestion(lines, response)
    return "\n".join(lines).rstrip()


def print_response(response: dict, output_format: str, human: bool) -> int:
    response = sanitize_response_errors(response)
    write_last_feedback_error(response)
    if human:
        output_format = "markdown"
    if output_format == "markdown":
        print(markdown_response(response))
    else:
        status = response.get("status")
        title = response.get("title")
        if output_format == "human":
            details = " ".join(part for part in [status, title] if part)
            print(f"{response.get('message', 'Barn Owl response.')} {details}".strip())
        else:
            print(json.dumps(response, sort_keys=True))
    return 0 if response.get("ok") else 1


def add_format(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--format", choices=["json", "markdown", "human"], default="json")
    parser.add_argument("--json", action="store_true", help="Force JSON output.")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="barnowl")
    parser.add_argument("--url", default=DEFAULT_URL)
    parser.add_argument("--human", action="store_true")
    parser.add_argument("--no-launch", action="store_true", help="Do not launch Barn Owl if the bridge is unavailable.")
    parser.add_argument("--format", choices=["json", "markdown", "human"], default="json")
    parser.add_argument("--json", action="store_true", help="Force JSON output.")
    subparsers = parser.add_subparsers(dest="command", required=True)

    add_format(subparsers.add_parser("status"))
    add_format(subparsers.add_parser("current"))

    wait = subparsers.add_parser("wait")
    wait_target = wait.add_mutually_exclusive_group(required=True)
    wait_target.add_argument("--session")
    wait_target.add_argument("--latest", action="store_true")
    wait.add_argument("--until", choices=["complete", "notes", "stopped"], default="complete")
    wait.add_argument("--timeout", type=parse_duration, default=parse_duration("10m"))
    add_format(wait)

    start = subparsers.add_parser("start")
    start.add_argument("--title")
    start.add_argument("--type", dest="meeting_type")
    start.add_argument("--context")
    start.add_argument("--source", default="cli")
    audio_group = start.add_mutually_exclusive_group()
    audio_group.add_argument("--with-system-audio", dest="captures_system_audio", action="store_true", default=True)
    audio_group.add_argument("--mic-only", dest="captures_system_audio", action="store_false")

    subparsers.add_parser("stop")

    meetings = subparsers.add_parser("meetings")
    meetings_subparsers = meetings.add_subparsers(dest="meetings_command", required=True)
    meetings_search = meetings_subparsers.add_parser("search")
    meetings_search.add_argument("query")
    meetings_search.add_argument("--limit", type=int, default=10)
    add_format(meetings_search)
    meetings_recent = meetings_subparsers.add_parser("recent")
    meetings_recent.add_argument("--limit", type=int, default=10)
    add_format(meetings_recent)
    meetings_evidence = meetings_subparsers.add_parser("evidence")
    meetings_evidence_sync = meetings_evidence.add_mutually_exclusive_group(required=True)
    meetings_evidence_sync.add_argument("--since")
    meetings_evidence_sync.add_argument("--cursor")
    meetings_evidence.add_argument("--limit", type=int, default=100)
    meetings_evidence.add_argument(
        "--policy",
        choices=[
            "metadata_only",
            "summary_transcript_and_pointers",
            "structured_outputs_transcript_and_pointers",
            "full_text_allowed",
        ],
    )
    meetings_evidence.add_argument("--include-transcript-segments", action="store_true")
    add_format(meetings_evidence)
    meetings_export_events = meetings_subparsers.add_parser("evidence-events")
    meetings_export_events_sync = meetings_export_events.add_mutually_exclusive_group(required=True)
    meetings_export_events_sync.add_argument("--since")
    meetings_export_events_sync.add_argument("--cursor")
    meetings_export_events.add_argument("--limit", type=int, default=100)
    add_format(meetings_export_events)

    meeting = subparsers.add_parser("meeting")
    meeting_subparsers = meeting.add_subparsers(dest="meeting_command", required=True)
    for name in ["get", "transcript", "notes", "summary", "context", "actions"]:
        leaf = meeting_subparsers.add_parser(name)
        leaf.add_argument("meeting_id")
        add_format(leaf)
    meeting_evidence = meeting_subparsers.add_parser("evidence")
    meeting_evidence.add_argument("meeting_id")
    meeting_evidence.add_argument(
        "--policy",
        choices=[
            "metadata_only",
            "summary_transcript_and_pointers",
            "structured_outputs_transcript_and_pointers",
            "full_text_allowed",
        ],
    )
    meeting_evidence.add_argument("--include-transcript-segments", action="store_true")
    add_format(meeting_evidence)
    meeting_delete = meeting_subparsers.add_parser("delete")
    meeting_delete.add_argument("meeting_id")
    meeting_delete.add_argument("--yes", action="store_true")
    add_format(meeting_delete)
    meeting_purge = meeting_subparsers.add_parser("purge-temp-audio")
    meeting_purge.add_argument("meeting_id")
    meeting_purge.add_argument("--yes", action="store_true")
    add_format(meeting_purge)

    jobs = subparsers.add_parser("jobs")
    jobs_subparsers = jobs.add_subparsers(dest="jobs_command", required=True)
    jobs_list = jobs_subparsers.add_parser("list")
    jobs_list.add_argument("--session")
    add_format(jobs_list)
    jobs_retry = jobs_subparsers.add_parser("retry")
    jobs_retry.add_argument("--session")
    jobs_retry.add_argument("--job")
    add_format(jobs_retry)
    jobs_dismiss = jobs_subparsers.add_parser("dismiss")
    jobs_dismiss.add_argument("--job", required=True)
    add_format(jobs_dismiss)

    summaries = subparsers.add_parser("summaries")
    summaries_subparsers = summaries.add_subparsers(dest="summaries_command", required=True)
    summaries_retry = summaries_subparsers.add_parser("retry")
    summary_target = summaries_retry.add_mutually_exclusive_group(required=True)
    summary_target.add_argument("--session")
    summary_target.add_argument("--all", action="store_true")
    add_format(summaries_retry)

    durability_repair = subparsers.add_parser("repair-durability")
    add_format(durability_repair)

    chat = subparsers.add_parser("chat")
    chat.add_argument("query")
    add_format(chat)

    ask_notes = subparsers.add_parser("ask-notes")
    ask_notes.add_argument("question")
    ask_notes.add_argument("--session")
    add_format(ask_notes)

    context = subparsers.add_parser("context")
    context_subparsers = context.add_subparsers(dest="context_command", required=True)
    context_add = context_subparsers.add_parser("add")
    context_add.add_argument("context", nargs="?")
    context_add.add_argument("--session")
    context_add.add_argument("--source", default="cli")
    context_set = context_subparsers.add_parser("set")
    context_set.add_argument("context", nargs="?")
    context_set.add_argument("--session")
    context_set.add_argument("--source", default="cli")
    context_list = context_subparsers.add_parser("list")
    context_list.add_argument("--session")
    add_format(context_list)
    for name in ["accept", "ignore", "delete"]:
        leaf = context_subparsers.add_parser(name)
        leaf.add_argument("context_id")
        add_format(leaf)

    diagnostics = subparsers.add_parser("diagnostics")
    diagnostics_subparsers = diagnostics.add_subparsers(dest="diagnostics_command", required=True)
    diagnostics_export = diagnostics_subparsers.add_parser("export")
    diagnostics_export.add_argument("--output", help="Path for the redacted Markdown diagnostics report.")
    add_format(diagnostics_export)

    permissions = subparsers.add_parser("permissions")
    permissions_subparsers = permissions.add_subparsers(dest="permissions_command", required=True)
    add_format(permissions_subparsers.add_parser("check"))
    add_format(permissions_subparsers.add_parser("test"))

    enrichment_sources = subparsers.add_parser("enrichment-sources")
    enrichment_subparsers = enrichment_sources.add_subparsers(dest="enrichment_sources_command", required=True)
    enrichment_list = enrichment_subparsers.add_parser("list")
    add_format(enrichment_list)
    enrichment_presets = enrichment_subparsers.add_parser("presets")
    add_format(enrichment_presets)
    enrichment_setup = enrichment_subparsers.add_parser("setup")
    enrichment_setup.add_argument("preset_id")
    enrichment_setup.add_argument("--source-id")
    enrichment_setup.add_argument("--name")
    enrichment_setup.add_argument("--authority")
    enrichment_setup.add_argument("--best-for", dest="best_used_for", action="append", default=[])
    enrichment_setup.add_argument("--disabled", action="store_true")
    enrichment_setup.add_argument("--config-json")
    enrichment_setup.add_argument("--connector-reference")
    enrichment_setup.add_argument("--privacy-copy-policy")
    enrichment_setup.add_argument("--query-budget-policy")
    add_format(enrichment_setup)
    enrichment_check = enrichment_subparsers.add_parser("check")
    enrichment_check.add_argument("source_id")
    add_format(enrichment_check)
    enrichment_upsert = enrichment_subparsers.add_parser("upsert")
    enrichment_upsert.add_argument("source_id")
    enrichment_upsert.add_argument("--name", required=True)
    enrichment_upsert.add_argument("--type", dest="source_type", required=True)
    enrichment_upsert.add_argument(
        "--scope",
        required=True,
        choices=["local_private", "personal_private", "workspace_private", "organization_scoped", "public"],
    )
    enrichment_upsert.add_argument("--authority", required=True)
    enrichment_upsert.add_argument("--best-for", dest="best_used_for", action="append", default=[])
    enrichment_upsert.add_argument("--disabled", action="store_true")
    enrichment_upsert.add_argument(
        "--auth-state",
        choices=["not_required", "configured", "needs_authentication", "unavailable"],
    )
    enrichment_upsert.add_argument(
        "--health-status",
        choices=["ready", "disabled", "needs_auth", "stale", "partial", "error"],
    )
    enrichment_upsert.add_argument("--config-json")
    enrichment_upsert.add_argument("--connector-reference")
    enrichment_upsert.add_argument("--privacy-copy-policy")
    enrichment_upsert.add_argument("--query-budget-policy")
    add_format(enrichment_upsert)
    for name in ["enable", "disable"]:
        leaf = enrichment_subparsers.add_parser(name)
        leaf.add_argument("source_id")
        add_format(leaf)

    authority_profiles = subparsers.add_parser("authority-profiles")
    authority_subparsers = authority_profiles.add_subparsers(dest="authority_profiles_command", required=True)
    add_format(authority_subparsers.add_parser("list"))
    authority_upsert = authority_subparsers.add_parser("upsert")
    authority_upsert.add_argument("profile_id")
    authority_upsert.add_argument("--name", required=True)
    authority_upsert.add_argument("--description", required=True)
    authority_upsert.add_argument("--strongest-for", dest="strongest_entity_kinds", action="append", default=[])
    authority_upsert.add_argument("--weakest-for", dest="weakest_entity_kinds", action="append", default=[])
    authority_upsert.add_argument("--weight", dest="default_weight", type=float)
    authority_upsert.add_argument("--auto-persist-policy-json")
    add_format(authority_upsert)

    policy_packs = subparsers.add_parser("policy-packs")
    policy_subparsers = policy_packs.add_subparsers(dest="policy_packs_command", required=True)
    add_format(policy_subparsers.add_parser("list"))
    policy_upsert = policy_subparsers.add_parser("upsert")
    policy_upsert.add_argument("policy_pack_id")
    policy_upsert.add_argument("--name", required=True)
    policy_upsert.add_argument("--description", required=True)
    policy_upsert.add_argument("--minimum-evidence", dest="minimum_supporting_evidence_count", type=int)
    policy_upsert.add_argument("--minimum-conflict-sources", dest="minimum_independent_source_count_after_conflict_memory", type=int)
    policy_upsert.add_argument("--active", action="store_true")
    add_format(policy_upsert)
    policy_activate = policy_subparsers.add_parser("activate")
    policy_activate.add_argument("policy_pack_id")
    add_format(policy_activate)

    knowledge = subparsers.add_parser("knowledge")
    knowledge_subparsers = knowledge.add_subparsers(dest="knowledge_command", required=True)
    knowledge_enrich = knowledge_subparsers.add_parser("enrich")
    knowledge_enrich.add_argument("query")
    knowledge_enrich.add_argument("--limit", type=int, default=8)
    add_format(knowledge_enrich)
    knowledge_jobs = knowledge_subparsers.add_parser("jobs")
    knowledge_jobs_subparsers = knowledge_jobs.add_subparsers(dest="knowledge_jobs_command", required=True)
    knowledge_jobs_list = knowledge_jobs_subparsers.add_parser("list")
    knowledge_jobs_list.add_argument("--limit", type=int, default=25)
    add_format(knowledge_jobs_list)
    knowledge_entities = knowledge_subparsers.add_parser("entities")
    knowledge_entities_subparsers = knowledge_entities.add_subparsers(dest="knowledge_entities_command", required=True)
    knowledge_entities_list = knowledge_entities_subparsers.add_parser("list")
    knowledge_entities_list.add_argument("--limit", type=int, default=100)
    add_format(knowledge_entities_list)
    for name in ["suppress", "reactivate"]:
        leaf = knowledge_entities_subparsers.add_parser(name)
        leaf.add_argument("entity_id")
        leaf.add_argument("--reason")
        add_format(leaf)

    feedback = subparsers.add_parser("feedback")
    feedback_subparsers = feedback.add_subparsers(dest="feedback_command", required=True)
    feedback_slack_parser = feedback_subparsers.add_parser("slack")
    feedback_slack_parser.add_argument("--yes", action="store_true", help="Post the redacted feedback draft to Slack.")
    feedback_slack_parser.add_argument("--force", action="store_true", help="Draft or post even for the owner user or without a current error.")
    feedback_slack_parser.add_argument("--output", help="Path for the redacted diagnostics report used by the draft.")
    add_format(feedback_slack_parser)

    title = subparsers.add_parser("title")
    title_subparsers = title.add_subparsers(dest="title_command", required=True)
    title_set = title_subparsers.add_parser("set")
    title_set.add_argument("title")
    title_set.add_argument("--session")

    meeting_type = subparsers.add_parser("type")
    type_subparsers = meeting_type.add_subparsers(dest="type_command", required=True)
    type_set = type_subparsers.add_parser("set")
    type_set.add_argument("meeting_type")
    type_set.add_argument("--session")

    notes = subparsers.add_parser("notes")
    notes_subparsers = notes.add_subparsers(dest="notes_command", required=True)
    notes_update = notes_subparsers.add_parser("update")
    notes_update.add_argument("prompt")
    notes_update.add_argument("--session")

    open_parser = subparsers.add_parser("open")
    open_subparsers = open_parser.add_subparsers(dest="open_command", required=True)
    open_subparsers.add_parser("current")
    open_subparsers.add_parser("latest")

    return parser


def main(argv: list[str]) -> int:
    launch = "--no-launch" not in argv
    argv = [argument for argument in argv if argument != "--no-launch"]
    args = build_parser().parse_args(argv)
    output_format = "json" if getattr(args, "json", False) else getattr(args, "format", "json")
    human = args.human

    if args.command == "status":
        return print_response(get_status(args.url, launch=launch), output_format, human)

    if args.command == "feedback" and args.feedback_command == "slack":
        return feedback_slack(args, args.url, launch, output_format, human)

    if args.command == "current":
        payload = {"command": "get_current"}
    elif args.command == "wait":
        payload = {
            "command": "wait",
            "sessionID": args.session,
            "latest": args.latest,
            "until": args.until,
            "format": output_format,
        }
        payload = {key: value for key, value in payload.items() if value is not None}
        return print_response(
            wait_for_condition(payload, args.url, timeout_seconds=args.timeout, launch=launch),
            output_format,
            human,
        )
    elif args.command == "start":
        payload = {
            "command": "start_recording",
            "title": args.title,
            "meetingType": args.meeting_type,
            "context": args.context,
            "source": args.source,
            "capturesSystemAudio": args.captures_system_audio,
        }
    elif args.command == "stop":
        payload = {"command": "stop_recording"}
    elif args.command == "meetings" and args.meetings_command == "search":
        payload = {
            "command": "meetings_search",
            "query": args.query,
            "limit": args.limit,
            "format": output_format,
        }
    elif args.command == "meetings" and args.meetings_command == "recent":
        payload = {
            "command": "meetings_recent",
            "limit": args.limit,
            "format": output_format,
        }
    elif args.command == "meetings" and args.meetings_command == "evidence":
        payload = {
            "command": "meetings_evidence",
            "since": args.since,
            "cursor": args.cursor,
            "limit": args.limit,
            "exportPolicy": args.policy,
            "includeTranscriptSegments": args.include_transcript_segments,
            "format": output_format,
        }
        payload = {key: value for key, value in payload.items() if value is not None}
    elif args.command == "meetings" and args.meetings_command == "evidence-events":
        payload = {
            "command": "meeting_export_events",
            "since": args.since,
            "cursor": args.cursor,
            "limit": args.limit,
            "format": output_format,
        }
        payload = {key: value for key, value in payload.items() if value is not None}
    elif args.command == "meeting":
        command_map = {
            "get": "meeting_get",
            "transcript": "meeting_transcript",
            "notes": "meeting_notes",
            "summary": "meeting_summary",
            "context": "meeting_context",
            "actions": "meeting_actions",
            "evidence": "meeting_evidence",
            "delete": "meeting_delete",
            "purge-temp-audio": "meeting_purge_temp_audio",
        }
        if args.meeting_command in {"delete", "purge-temp-audio"} and not args.yes:
            response = {
                "ok": False,
                "message": f"`barnowl meeting {args.meeting_command}` is destructive and requires --yes.",
                "meetingID": args.meeting_id,
                "errorCode": "confirmation_required",
                "error": "Pass --yes to confirm.",
            }
            return print_response(response, output_format, human)
        payload = {
            "command": command_map[args.meeting_command],
            "meetingID": args.meeting_id,
            "confirmed": getattr(args, "yes", None),
            "exportPolicy": getattr(args, "policy", None),
            "includeTranscriptSegments": getattr(args, "include_transcript_segments", None),
            "format": output_format,
        }
        payload = {key: value for key, value in payload.items() if value is not None}
    elif args.command == "jobs":
        if args.jobs_command == "list":
            payload = {
                "command": "jobs_list",
                "sessionID": args.session,
                "format": output_format,
            }
        elif args.jobs_command == "retry":
            payload = {
                "command": "jobs_retry",
                "sessionID": args.session,
                "jobID": args.job,
                "format": output_format,
            }
        elif args.jobs_command == "dismiss":
            payload = {
                "command": "jobs_dismiss",
                "jobID": args.job,
                "format": output_format,
            }
        else:
            raise AssertionError(f"unhandled jobs command: {args.jobs_command}")
    elif args.command == "summaries":
        if args.summaries_command == "retry":
            payload = {
                "command": "summaries_retry",
                "sessionID": args.session,
                "all": args.all,
                "format": output_format,
            }
        else:
            raise AssertionError(f"unhandled summaries command: {args.summaries_command}")
    elif args.command == "repair-durability":
        payload = {
            "command": "durability_repair",
            "format": output_format,
        }
    elif args.command == "chat":
        payload = {"command": "chat", "query": args.query, "format": output_format}
    elif args.command == "ask-notes":
        payload = {
            "command": "ask_notes",
            "sessionID": args.session,
            "query": args.question,
            "format": output_format,
        }
    elif args.command == "context" and args.context_command in {"add", "set"}:
        context = args.context if args.context is not None else sys.stdin.read()
        payload = {
            "command": "append_context" if args.context_command == "add" else "set_context",
            "sessionID": args.session,
            "context": context,
            "source": args.source,
        }
    elif args.command == "context" and args.context_command == "list":
        payload = {
            "command": "context_list",
            "sessionID": args.session,
            "format": output_format,
        }
    elif args.command == "context" and args.context_command in {"accept", "ignore", "delete"}:
        payload = {
            "command": f"context_{args.context_command}",
            "contextItemID": args.context_id,
            "format": output_format,
        }
    elif args.command == "diagnostics" and args.diagnostics_command == "export":
        output_path = args.output
        if output_path is None:
            timestamp = time.strftime("%Y%m%d-%H%M%S", time.gmtime())
            output_path = str(Path.cwd() / f"BarnOwl-developer-diagnostics-{timestamp}.md")
        payload = {
            "command": "diagnostics_export",
            "outputPath": output_path,
            "format": output_format,
        }
    elif args.command == "permissions" and args.permissions_command == "check":
        payload = {
            "command": "permissions_check",
            "format": output_format,
        }
    elif args.command == "permissions" and args.permissions_command == "test":
        payload = {
            "command": "permissions_test",
            "format": output_format,
        }
    elif args.command == "enrichment-sources" and args.enrichment_sources_command == "list":
        payload = {
            "command": "enrichment_sources_list",
            "format": output_format,
        }
    elif args.command == "enrichment-sources" and args.enrichment_sources_command == "presets":
        payload = {
            "command": "enrichment_source_presets_list",
            "format": output_format,
        }
    elif args.command == "enrichment-sources" and args.enrichment_sources_command == "setup":
        payload = {
            "command": "enrichment_source_setup_preset",
            "presetID": args.preset_id,
            "sourceID": args.source_id,
            "sourceDisplayName": args.name,
            "authorityProfile": args.authority,
            "bestUsedFor": args.best_used_for or None,
            "enabled": not args.disabled,
            "configJSON": args.config_json,
            "connectorReference": args.connector_reference,
            "privacyCopyPolicy": args.privacy_copy_policy,
            "queryBudgetPolicy": args.query_budget_policy,
            "format": output_format,
        }
    elif args.command == "enrichment-sources" and args.enrichment_sources_command == "check":
        payload = {
            "command": "enrichment_source_health_check",
            "sourceID": args.source_id,
            "format": output_format,
        }
    elif args.command == "enrichment-sources" and args.enrichment_sources_command == "upsert":
        payload = {
            "command": "enrichment_source_upsert",
            "sourceID": args.source_id,
            "sourceDisplayName": args.name,
            "sourceType": args.source_type,
            "scope": args.scope,
            "authorityProfile": args.authority,
            "bestUsedFor": args.best_used_for,
            "enabled": not args.disabled,
            "authState": args.auth_state,
            "healthStatus": args.health_status,
            "configJSON": args.config_json,
            "connectorReference": args.connector_reference,
            "privacyCopyPolicy": args.privacy_copy_policy,
            "queryBudgetPolicy": args.query_budget_policy,
            "format": output_format,
        }
    elif args.command == "enrichment-sources" and args.enrichment_sources_command in {"enable", "disable"}:
        payload = {
            "command": f"enrichment_source_{args.enrichment_sources_command}",
            "sourceID": args.source_id,
            "format": output_format,
        }
    elif args.command == "authority-profiles" and args.authority_profiles_command == "list":
        payload = {
            "command": "enrichment_authority_profiles_list",
            "format": output_format,
        }
    elif args.command == "authority-profiles" and args.authority_profiles_command == "upsert":
        payload = {
            "command": "enrichment_authority_profile_upsert",
            "authorityProfileID": args.profile_id,
            "displayName": args.name,
            "description": args.description,
            "strongestEntityKinds": args.strongest_entity_kinds,
            "weakestEntityKinds": args.weakest_entity_kinds,
            "defaultWeight": args.default_weight,
            "autoPersistPolicyJSON": args.auto_persist_policy_json,
            "format": output_format,
        }
    elif args.command == "policy-packs" and args.policy_packs_command == "list":
        payload = {
            "command": "enrichment_policy_packs_list",
            "format": output_format,
        }
    elif args.command == "policy-packs" and args.policy_packs_command == "upsert":
        payload = {
            "command": "enrichment_policy_pack_upsert",
            "policyPackID": args.policy_pack_id,
            "displayName": args.name,
            "description": args.description,
            "minimumSupportingEvidenceCount": args.minimum_supporting_evidence_count,
            "minimumIndependentSourceCountAfterConflictMemory": args.minimum_independent_source_count_after_conflict_memory,
            "enabled": args.active,
            "format": output_format,
        }
    elif args.command == "policy-packs" and args.policy_packs_command == "activate":
        payload = {
            "command": "enrichment_policy_pack_activate",
            "policyPackID": args.policy_pack_id,
            "format": output_format,
        }
    elif args.command == "knowledge" and args.knowledge_command == "enrich":
        payload = {
            "command": "knowledge_enrich",
            "query": args.query,
            "limit": args.limit,
            "format": output_format,
        }
    elif args.command == "knowledge" and args.knowledge_command == "jobs" and args.knowledge_jobs_command == "list":
        payload = {
            "command": "knowledge_jobs_list",
            "limit": args.limit,
            "format": output_format,
        }
    elif args.command == "knowledge" and args.knowledge_command == "entities" and args.knowledge_entities_command == "list":
        payload = {
            "command": "knowledge_entities_list",
            "limit": args.limit,
            "format": output_format,
        }
    elif args.command == "knowledge" and args.knowledge_command == "entities" and args.knowledge_entities_command in {"suppress", "reactivate"}:
        payload = {
            "command": f"knowledge_entity_{args.knowledge_entities_command}",
            "knowledgeEntityID": args.entity_id,
            "reason": args.reason,
            "format": output_format,
        }
    elif args.command == "title" and args.title_command == "set":
        payload = {"command": "set_title", "sessionID": args.session, "title": args.title}
    elif args.command == "type" and args.type_command == "set":
        payload = {
            "command": "set_meeting_type",
            "sessionID": args.session,
            "meetingType": args.meeting_type,
        }
    elif args.command == "notes" and args.notes_command == "update":
        payload = {"command": "update_notes", "sessionID": args.session, "prompt": args.prompt}
    elif args.command == "open" and args.open_command == "current":
        payload = {"command": "open_current_meeting"}
    elif args.command == "open" and args.open_command == "latest":
        payload = {"command": "open_latest_meeting"}
    else:
        raise AssertionError(f"unhandled command: {args.command}")

    payload = {key: value for key, value in payload.items() if value is not None}
    return print_response(post(payload, args.url, launch=launch), output_format, human)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
